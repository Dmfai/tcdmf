# MongoDB 连接字符串（本地或 Atlas）
MONGO_URI=mongodb://127.0.0.1:27017/studio

# 站点根地址（用于 SEO / sitemap）
SITE_URL=http://localhost:3000

# 管理端账号（用于登录获取 token）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# 管理端 token（长随机串，建议 >= 32 字节）
# 可用 `openssl rand -hex 32` 生成
ADMIN_TOKEN=replace-with-a-long-random-hex-string
